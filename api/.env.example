# WorkPulse Connect API — environment template
# Copy to `.env` and fill in real values. Never commit `.env`.

# Server
PORT=8000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/workpulse

# JWT (required) — use a long random secret in production
JWT_KEY=change-me-to-a-long-random-secret

# Auth cookies (login / logout must use the same flags)
# In production (or any HTTPS + cross-origin frontend), set COOKIE_SECURE=true
# so cookies use SameSite=None; Secure. Local HTTP defaults to SameSite=Lax.
COOKIE_SECURE=false

# bcrypt cost for new password hashes (default 12)
BCRYPT_SALT_ROUNDS=12

# Paystack (orders) — production payment rail
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
# Optional public key for future inline JS checkout
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
# Currency for initialize (default GHS — amounts sent in pesewas)
PAYSTACK_CURRENCY=GHS
# Webhook uses HMAC SHA512 of the raw body with PAYSTACK_SECRET_KEY
# (no separate webhook secret). Register https://<api-host>/api/orders/webhook
# on the Paystack Dashboard and subscribe to charge.success.

# Platform take rate on paid orders (percent). Default 10 → seller keeps 90%.
MIN_PAYOUT_AMOUNT=10

# Frontend origin (email deep links + Paystack callback). Use the Next.js app URL.
CLIENT_URL=http://localhost:3000
DOMAIN=localhost

# Socket.IO (Feature 14) — same server as REST; optional path override
SOCKET_PATH=/socket.io

# Email / SMTP (optional — without these, Ethereal test accounts may be used)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=WorkPulse Connect <noreply@localhost>
EMAIL_DEBUG=false
EMAIL_CONN_TIMEOUT=10000
EMAIL_GREETING_TIMEOUT=10000
EMAIL_SOCKET_TIMEOUT=10000
EMAIL_TLS_REJECT_UNAUTHORIZED=true
EMAIL_FALLBACK_TO_ETHEREAL=false
